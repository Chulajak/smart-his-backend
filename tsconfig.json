{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    
    /* เพิ่ม 2 บรรทัดนี้เข้ามาเพื่อแก้ปัญหา */
    "allowJs": true, 
    "verbatimModuleSyntax": false
  }
}